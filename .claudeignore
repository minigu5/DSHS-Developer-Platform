# =============================================================================
# .claudeignore — Claude Code 토큰 절약용 제외 패턴
# =============================================================================
# Claude가 자동으로 읽거나 인덱싱하지 않아야 할 파일/디렉토리.
# .gitignore 와 동일한 glob 문법.
# =============================================================================

# ---- 의존성 (가장 큰 토큰 절약 효과) ----
node_modules/
.pnp
.pnp.*
.yarn/

# ---- Next.js 빌드 산출물 ----
.next/
out/
build/
dist/

# ---- 캐시 / 임시 파일 ----
.cache/
.turbo/
.swc/
.vercel/
.vscode/
.idea/
*.tsbuildinfo
next-env.d.ts

# ---- 테스트 / 커버리지 ----
coverage/
.nyc_output/
playwright-report/
test-results/

# ---- 로그 ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- 락 파일 (매우 큼, 직접 편집 불필요) ----
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---- 환경 변수 / 시크릿 ----
.env
.env.*
!.env.local.example
!.env.example

# ---- OS / 에디터 메타데이터 ----
.DS_Store
Thumbs.db
*.swp
*.swo

# ---- 바이너리 / 미디어 (텍스트 분석 불필요) ----
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.pdf
*.zip
*.tar
*.tar.gz
*.mp4
*.mov
*.woff
*.woff2
*.ttf
*.otf
*.eot

# 단, public/ 아이콘/로고 등은 필요 시 예외 처리
# !public/logo.svg

# ---- Supabase 로컬 개발 산출물 ----
supabase/.branches/
supabase/.temp/

# ---- 본 프로젝트 보안 주의 항목 ----
# 실명 매핑 등 민감 데이터 (CLAUDE.md 보안 섹션 참고)
**/student_mappings*.json
**/student_mappings*.csv
**/*real_names*

# ---- 대용량 문서/마이그레이션 결과물 ----
docs/archive/
docs/*.backup.md

# ---- 인증서 / 키 ----
*.pem
*.key
*.crt

# ---- shadcn/ui 자동 생성 컴포넌트 ----
# Claude는 shadcn API를 이미 알고 있음. 주요 차이점은 CLAUDE.md에 문서화됨.
src/components/ui/

# ---- 자동 생성 타입 파일 ----
# Supabase CLI 생성 타입. 수동 작성 types.ts 가 source of truth.
src/lib/types.generated.ts

# ---- Supabase 마이그레이션 스냅샷 ----
# 자동 생성된 원격 스키마 덤프. source of truth는 docs/03-supabase-schema.sql.
supabase/migrations/

# ---- 인간용 셋업 문서 ----
# 초기 환경 구성 가이드. 핵심 스키마(SQL)는 제외하지 않음.
docs/01-supabase-setup.md
docs/02-google-oauth-setup.md

# ---- 인간/다른 AI용 문서 ----
README.md
AGENTS.md
LICENSE

# ---- 정적 에셋 디렉토리 ----
# *.svg 패턴으로 이미 차단되지만 명시적으로 제외.
public/

# ---- 일회성 유틸 스크립트 ----
scripts/

# ---- 빌드·설정 파일 ----
eslint.config.mjs
postcss.config.mjs
components.json
