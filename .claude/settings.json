{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(node_modules/**)",
      "Read(.next/**)",
      "Read(build/**)",
      "Read(dist/**)",
      "Read(.cache/**)",
      "Read(.turbo/**)",
      "Read(coverage/**)",
      "Read(*.tsbuildinfo)",
      "Read(package-lock.json)",
      "Read(yarn.lock)",
      "Read(pnpm-lock.yaml)",
      "Read(*.log)",
      "Read(**/student_mappings*)",
      "Read(*.png)",
      "Read(*.jpg)",
      "Read(*.jpeg)",
      "Read(*.gif)",
      "Read(*.webp)",
      "Read(*.ico)",
      "Read(*.pdf)",
      "Read(*.woff)",
      "Read(*.woff2)",
      "Read(*.ttf)"
    ]
  }
}
