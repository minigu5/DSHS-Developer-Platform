# =====================================================================
# DSHS Developer Platform — 환경 변수 템플릿
# ---------------------------------------------------------------------
# 이 파일을 복사해서 `.env.local` 파일을 만들고 값을 채우세요.
#
#   cp .env.local.example .env.local
#
# ⚠️ 이 파일(.example)에는 절대 실제 값을 넣지 마세요!
# ⚠️ `.env.local` 파일은 절대 Git에 커밋하지 마세요. (.gitignore 자동 처리됨)
# =====================================================================


# ---------------------------------------------------------------------
# [1] Supabase
# ---------------------------------------------------------------------
# 📍 위치: Supabase 대시보드 → ⚙️ Project Settings → API
# 가이드: docs/01-supabase-setup.md 의 "3️⃣ API Keys 확인 및 복사" 섹션

# Project URL (예: https://abcdefghijklmno.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon public key (eyJhbGc... 로 시작하는 긴 JWT)
# 클라이언트 노출 OK — RLS가 보안 책임
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role secret key (eyJhbGc... 로 시작하는 긴 JWT)
# ⚠️ 절대 클라이언트 노출 금지! 서버에서만 사용
SUPABASE_SERVICE_ROLE_KEY=


# ---------------------------------------------------------------------
# [2] Application
# ---------------------------------------------------------------------
# 로컬 개발 시에는 그대로 두세요. 배포 후 Vercel URL로 변경합니다.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 로그인 허용 이메일 도메인 (변경하지 마세요)
ALLOWED_EMAIL_DOMAIN=ts.hs.kr
